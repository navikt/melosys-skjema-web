{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:ci": "tsc && rm -rf build && mkdir -p build && cp -r dist build/dist && cp package.json build/package.json && cp pnpm-lock.yaml build/pnpm-lock.yaml && cp .npmrc build/.npmrc && cd build && pnpm install --prod --frozen-lockfile && cp -r ../../app/dist public",
    "dev": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "check-types": "tsc --noemit",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "author": "NAV",
  "license": "MIT",
  "dependencies": {
    "@navikt/nav-dekoratoren-moduler": "3.7.1",
    "@navikt/oasis": "4.1.4",
    "@navikt/vite-mode": "0.13.7",
    "express": "5.2.1",
    "express-rate-limit": "8.4.0",
    "http-proxy-middleware": "3.0.5",
    "morgan": "1.10.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "overrides": {
      "undici": "^7.25.0"
    }
  }
}

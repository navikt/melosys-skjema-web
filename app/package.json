{
  "name": "app",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check-types": "tsc --noemit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "generate-types": "swagger-typescript-api generate --path ${SWAGGER_BASE_URL:-https://melosys-skjema-api.intern.dev.nav.no}/v3/api-docs --output ./src/types --union-enums --no-client -n melosysSkjemaTypes",
    "sync-skjema-definisjon": "tsx scripts/sync-skjema-definisjon.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@navikt/aksel-icons": "8.13.0",
    "@navikt/ds-css": "8.13.0",
    "@navikt/ds-react": "8.13.0",
    "@navikt/ds-tailwind": "8.13.0",
    "@navikt/fnrvalidator": "^2.2.1",
    "@navikt/nav-dekoratoren-moduler": "3.7.1",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "date-fns": "^4.4.0",
    "i18next": "26.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-i18next": "17.0.8",
    "tailwindcss": "^4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.10.1",
    "@eslint/js": "10.0.1",
    "@navikt/aksel-stylelint": "8.14.0",
    "@playwright/test": "1.61.1",
    "@tanstack/router-vite-plugin": "1.167.19",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "baseline-browser-mapping": "^2.10.41",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "swagger-typescript-api": "13.12.4",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "overrides": {
      "undici": "^7.25.0"
    }
  }
}
